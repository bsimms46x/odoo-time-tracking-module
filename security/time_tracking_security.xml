<odoo>
    <record id="group_time_tracker" model="res.groups">
        <field name="name">Time Tracking User</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>
    <record id="group_time_manager" model="res.groups">
        <field name="name">Time Tracking Manager</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="implied_ids" eval="[(4, ref('time_tracking_module.group_time_tracker'))]"/>
    </record>

    <record id="model_x_time_entry" model="ir.model">
        <field name="name">x_time_entry</field>
        <field name="model">x_time_entry</field>
        <field name="state">manual</field>
    </record>

    <record id="model_x_time_entry_batch" model="ir.model">
        <field name="name">x_time_entry_batch</field>
        <field name="model">x_time_entry_batch</field>
        <field name="state">manual</field>
    </record>

    <record id="model_x_time_entry_approval" model="ir.model">
        <field name="name">x_time_entry_approval</field>
        <field name="model">x_time_entry_approval</field>
        <field name="state">manual</field>
    </record>

    <record id="model_x_time_rule_policy" model="ir.model">
        <field name="name">x_time_rule_policy</field>
        <field name="model">x_time_rule_policy</field>
        <field name="state">manual</field>
    </record>

    <record id="model_x_time_sheet_template" model="ir.model">
        <field name="name">x_time_sheet_template</field>
        <field name="model">x_time_sheet_template</field>
        <field name="state">manual</field>
    </record>

    <record id="rule_time_entry_owner" model="ir.rule">
        <field name="name">Time entries: own employee</field>
        <field name="model_id" ref="model_x_time_entry"/>
        <field name="groups" eval="[(4, ref('time_tracking_module.group_time_tracker'))]"/>
    </record>

    <record id="rule_time_entry_manager" model="ir.rule">
        <field name="name">Time entries: managed teams</field>
        <field name="model_id" ref="model_x_time_entry"/>
        <field name="groups" eval="[(4, ref('time_tracking_module.group_time_manager'))]"/>
    </record>
</odoo>
