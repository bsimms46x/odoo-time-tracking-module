<odoo>
    <record id="time_rule_tree" model="ir.ui.view">
        <field name="name">time.rule.policy.tree</field>
        <field name="model">time.rule.policy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="billable_type"/>
                <field name="price_per_unit"/>
                <field name="account_id"/>
            </list>
        </field>
    </record>

    <record id="time_rule_form" model="ir.ui.view">
        <field name="name">time.rule.policy.form</field>
        <field name="model">time.rule.policy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="billable_type"/>
                        <field name="price_per_unit"/>
                        <field name="account_id" context="{'default_internal_type': 'other'}"/>
                        <field name="analytic_account_id"/>
                    </group>
                    <group>
                        <field name="project_ids" widget="many2many_tags"/>
                        <field name="tag_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="time_rule_action" model="ir.actions.act_window">
        <field name="name">Billing Policies</field>
        <field name="res_model">time.rule.policy</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="time_rule_tree"/>
    </record>

    <record id="time_rule_menu" model="ir.ui.menu">
        <field name="name">Billing Policies</field>
        <field name="parent_id" ref="time_tracking_module.menu_time_tracking"/>
        <field name="action" ref="time_rule_action"/>
    </record>
</odoo>
